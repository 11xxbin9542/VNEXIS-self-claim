{
  "name": "vnexis",
  "version": "4.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "cd apps/web && npm run dev",
    "build": "cd apps/web && npm run build",
    "api:dev": "cd apps/api && uvicorn main:app --reload --host 0.0.0.0 --port 8000",
    "api:prod": "cd apps/api && uvicorn main:app --host 0.0.0.0 --port $PORT",
    "lint": "cd apps/web && npm run lint",
    "bulk": "cd scripts && python bulk_processor.py"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
